{
  "name": "egographica-discord-bot",
  "version": "1.0.0",
  "description": "Discord Bot for recording voice channels",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx app/index.ts",
    "build": "tsc -p .",
    "start": "node dist/index.js",
    "deploy": "tsx app/deploy.ts",
    "lint": "eslint app/**/*.ts",
    "lint:fix": "eslint app/**/*.ts --fix",
    "format": "prettier --write \"app/**/*.ts\"",
    "format:check": "prettier --check \"app/**/*.ts\""
  },
  "keywords": ["discord", "bot", "recording"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@discordjs/voice": "^0.17.0",
    "discord.js": "^14.14.1",
    "dotenv": "^16.4.5",
    "firebase-admin": "^12.0.0",
    "fluent-ffmpeg": "^2.1.3",
    "openai": "^4.28.0",
    "opusscript": "^0.0.8",
    "prism-media": "^1.3.5",
    "wav": "^1.0.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/node": "^20.11.19",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

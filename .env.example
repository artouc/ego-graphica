# Discord Bot Configuration
# Discord Bot トークンとクライアントID（必須）
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here

# Discord ギルドID（オプション - 指定するとギルド固有のコマンドとして即座に反映）
# 未指定の場合はグローバルコマンドとして登録（反映まで最大1時間）
DISCORD_GUILD_ID=

# Firebase Storage Configuration（オプション - 録音ファイルの自動アップロード）
# Firebase Console > Project Settings > Service Accounts > Generate new private key から取得
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# Data Storage
# 録音データと設定の保存先（デフォルト: ./var/data）
DATA_DIR=./var/data

# Recording Settings
# 無音検出までの時間（ミリ秒）
AFTER_SILENCE_MS=800

# 録音セグメントの最大秒数
RECORDING_SEGMENT_SECONDS=5

# MP3変換のビットレート（kbps）
# 推奨: 128 (高音質) または 64 (標準音質)
MP3_BITRATE=128

# Environment
# 実行環境（development, production, test）
NODE_ENV=development

# タイムゾーン
TIMEZONE=Asia/Tokyo

# ポート番号（予約値）
PORT=3080
